# Copia este archivo como .env y reemplaza los valores antes de ejecutar el proyecto.

# Base de datos
DATABASE_URL=sqlite:///./device_systems.db

# Seguridad JWT
# Genera una clave propia con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=reemplaza_esto_con_una_clave_secreta_unica
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS - orígenes permitidos separados por coma
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
